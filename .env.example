# Payment Provider Configuration
# Stripe (for Credit/Debit Cards)
STRIPE_SECRET_KEY=st_test

# Flutterwave (for MTN/Airtel Mobile Money in Uganda)
FLW_SECRET_KEY=FLWSECK_TEST-...
FLW_PUBLIC_KEY=FLWPUBK_TEST-...

# Server Base URL (use your production domain in production)
BASE_URL=http://localhost:3000

# Email Configuration (for contact form notifications)
# If not set, submissions are saved to submissions.json only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@risetogether.org
EMAIL_TO=info@risetogether.org
